{
  "name": "cinecircle-root",
  "version": "1.0.0",
  "description": "Root workspace of CineCircle Movie Planning Platform",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jspdf": "^4.2.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6"
  }
}
